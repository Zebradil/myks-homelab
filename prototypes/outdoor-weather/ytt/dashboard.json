  "templating": {
    "list": [
      {
        "type": "query",
        "name": "serialno",
        "skipUrlSync": false,
        "query": "label_values(airgradient_config_info,serialno)",
        "datasource": {
          "type": "prometheus"
        },
        "multi": true,
        "allowCustomValue": true,
        "refresh": 1,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "auto": false,
        "auto_min": "10s",
        "auto_count": 30
