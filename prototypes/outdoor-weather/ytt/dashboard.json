{
  "uid": "outdoor-weather-compare",
  "title": "Indoor vs Outdoor",
  "description": "Compares AirGradient indoor air quality against outdoor weather (Open-Meteo) and air quality (UBA).",
  "tags": [
    "airgradient",
    "outdoor",
    "weather"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "5m",
  "schemaVersion": 42,
  "panels": [
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg by(serialno) (airgradient_atmp{serialno=~\"$serialno\"})",
          "editorMode": "code",
          "legendFormat": "Indoor {{serialno}}"
        },
        {
          "expr": "avg without(source, station) (outdoor_temp_celsius)",
          "editorMode": "code",
          "legendFormat": "Outdoor"
        }
      ],
      "title": "Temperature — Indoor vs Outdoor",
      "description": "Indoor AirGradient ambient temperature vs outdoor temperature at the configured coordinates (Open-Meteo).",
      "transparent": false,
      "datasource": {
        "type": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "repeatDirection": "h",
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "min",
            "max",
            "mean"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2,
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "targets": [
        {
          "expr": "avg by(serialno) (airgradient_rhum{serialno=~\"$serialno\"})",
          "editorMode": "code",
          "legendFormat": "Indoor {{serialno}}"
        },
        {
          "expr": "avg without(source, station) (outdoor_humidity_percent)",
          "editorMode": "code",
          "legendFormat": "Outdoor"
        }
      ],
      "title": "Relative Humidity — Indoor vs Outdoor",
