#!/usr/bin/env bash

# Refresh Argo CD application by setting the refresh annotation on its
# Application CR. The application controller picks up the annotation, refreshes
# the app, and removes the annotation when done.
#
# Uses the current kubectl context (must be set before running this plugin).

set -euo pipefail

ctx="${ARGOCD_CONTEXT:?}"
ns="${ARGOCD_NAMESPACE:-argocd}"
app="app-${MYKS_ENV}-${MYKS_APP}"

function k() {
    kubectl --context "$ctx" --namespace "$ns" "$@"
}

if ! k get application "$app" &>/dev/null; then
    echo "argo-refresh: app '$app' not found in ArgoCD — skipping refresh." >&2
    echo "argo-refresh: this is expected for apps just added in this branch; the parent app-of-apps will create it on its next sync." >&2
    exit 0
fi

k patch application "$app" --type merge \
    -p '{"metadata":{"annotations":{"argocd.argoproj.io/refresh":"normal"}}}' >/dev/null

echo "argo-refresh: triggered refresh for '$app'."
